# Required — your BuilderBlack tenant slug. The piece before
# `.builderblack.com` in your default subdomain. Find it in the
# dashboard sidebar under your store name.
NEXT_PUBLIC_BB_TENANT_SLUG=your-store-slug

# Required — the BuilderBlack API base URL.
NEXT_PUBLIC_BB_API_URL=https://api.builderblack.com

# Optional but recommended — read-only Storefront API token.
# Issue from your dashboard at app.builderblack.com/settings/api-tokens.
# Server-only — DO NOT prefix with NEXT_PUBLIC_ (would expose to browser).
# Without it: anonymous endpoints work, capped at 600 req/min per IP.
# With it: elevated rate limits (6000 req/min) + longer CDN cache TTL.
BB_STOREFRONT_TOKEN=bb_sft_replace_with_your_token
